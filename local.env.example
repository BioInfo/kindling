# Per-deployment overrides for run.sh / start-prod.sh. Copy to local.env
# (gitignored) and edit. Anything you can also pre-set in the environment.
# Secrets (Plaid keys, gateway API key) come from `pass` or env — see run.sh;
# don't put them here unless you accept plaintext-on-disk.

# Your OpenAI-compatible LLM gateway (LiteLLM, vLLM, Ollama, OpenRouter, ...)
#export LITELLM_BASE_URL="http://localhost:4000/v1"

# Model the categorize/summarize/chat paths use (default in lib/config.ts).
#export FINANCE_LLM_MODEL="deepseek-v4-flash"

# Optional self-hosted web-search gateway (merchant identify, scam check,
# asset estimates). Features degrade cleanly when unset/unreachable.
#export LITESEARCH_URL="http://localhost:8899"

# Override the chat model picker without a code change (JSON, see
# app/api/models/route.ts for the shape).
#export FINANCE_MODELS='[{"id":"llama3","label":"Llama 3 (local)","location":"local","provider":"Ollama","blurb":"Stays on your network"}]'
